# Optional — copy this file to ".env" to override config.json values
# without editing the file directly. Useful when deploying to a host
# (Railway, Render, Pterodactyl, etc.) where you set env vars in a dashboard.

MC_HOST=your-server-ip
MC_PORT=25565
MC_VERSION=1.21.4
MC_USERNAME=aurora_assistant
MC_AUTH=offline
MC_PASSWORD=
